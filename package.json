{
  "name": "kartik-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:all": "node scripts/dev.js",
    "dev:db": "mongod --dbpath .mongodb-data --bind_ip 127.0.0.1 --port 27017",
    "dev:frontend": "npm --workspace kartik-portfolio-frontend run dev",
    "dev:backend": "npm --workspace kartik-portfolio-backend run dev",
    "build": "npm run build:frontend",
    "build:frontend": "npm --workspace kartik-portfolio-frontend run build",
    "lint": "eslint frontend/src backend",
    "preview": "npm --workspace kartik-portfolio-frontend run preview",
    "seed": "npm --workspace kartik-portfolio-backend run seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0"
  }
}
